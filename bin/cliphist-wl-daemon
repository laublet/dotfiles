#!/usr/bin/env bash
# Wayland clipboard history daemon (cliphist + wl-clipboard). X11: use greenclip instead.
set -euo pipefail

if [[ "${XDG_SESSION_TYPE:-}" != wayland ]] && [[ -z "${WAYLAND_DISPLAY:-}" ]]; then
  echo "cliphist-wl: not a Wayland session — use: greenclip daemon &" >&2
  exit 1
fi

if ! command -v cliphist &>/dev/null || ! command -v wl-paste &>/dev/null; then
  echo "cliphist-wl: install cliphist and wl-clipboard" >&2
  exit 1
fi

wl-paste --type text --watch cliphist store &
wl-paste --type image --watch cliphist store &
