#!/usr/bin/env bash
# mac-borders — JankyBorders with Dracula colors (matches aerospace.toml after-startup-command).
#
# Do NOT use `brew services start borders` — it starts borders without args and blocks
# the colored instance (single-instance app).
#
# Usage:
#   mac-borders              Restart with dotfiles colors
#   mac-borders --stop       Quit borders
#   mac-borders --dry-run    Print command only

set -euo pipefail

if [[ "$(uname)" != "Darwin" ]]; then
  echo "macOS only." >&2
  exit 1
fi

DRY_RUN=0
STOP=0
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    --stop) STOP=1 ;;
    -h|--help)
      sed -n '2,12p' "$0"
      exit 0
      ;;
    *)
      echo "Unknown option: $arg" >&2
      exit 1
      ;;
  esac
done

command -v borders >/dev/null 2>&1 || {
  echo "Missing: borders (brew tap felixkratz/formulae && brew install borders)" >&2
  exit 1
}

DOTFILES="${DOTFILES:-$HOME/dev/perso/dotfiles}"
ENV_FILE="${DOTFILES}/conf/theme/dracula.env"
[[ -f "$ENV_FILE" ]] && source "$ENV_FILE"

BORDERS_CMD=(
  borders
  style=round
  "active_color=${DRACULA_BORDERS_ACTIVE_GRADIENT:-gradient(top_left=0xffbd93f9,bottom_right=0xffff79c6)}"
  "inactive_color=${DRACULA_BORDERS_INACTIVE_COLOR:-0xff44475a}"
  "width=${DRACULA_BORDERS_WIDTH:-4.0}"
  hidpi=on
)

run() {
  if (( DRY_RUN )); then
    printf '%q ' "${BORDERS_CMD[@]}"
    echo
  else
    "${BORDERS_CMD[@]}"
  fi
}

if (( STOP )); then
  brew services stop borders 2>/dev/null || true
  pkill borders 2>/dev/null || true
  echo "borders stopped."
  exit 0
fi

brew services stop borders 2>/dev/null || true
pkill borders 2>/dev/null || true
sleep 0.3

echo "Starting borders (active: purple→pink, inactive from dracula.env)…"
if (( DRY_RUN )); then
  run
else
  nohup "${BORDERS_CMD[@]}" >/dev/null 2>&1 &
  sleep 0.5
  if pgrep -xq borders; then
    echo "Done. Re-login also runs this via AeroSpace after-startup-command."
  else
    echo "borders failed to start." >&2
    exit 1
  fi
fi
