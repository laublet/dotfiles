#!/usr/bin/env bash
# mac-video-defaults — Finder defaults for video types that clash with dev extensions.
#
# On macOS, ".ts" is public.mpeg-2-transport-stream (MPEG transport), NOT TypeScript.
# Run after mac-neovim-defaults if Neovim/Cursor was set for ".ts" by mistake.
#
# TypeScript sources: open via terminal (nvim path.ts), or use .tsx in Finder.
#
# Requires: IINA (brew install --cask iina), duti (brew install duti)
#
# Usage:
#   mac-video-defaults
#   mac-video-defaults --dry-run
#   mac-video-defaults --force

set -euo pipefail

if [[ "$(uname)" != "Darwin" ]]; then
  echo "macOS only." >&2
  exit 1
fi

DRY_RUN=0
FORCE=0
for arg in "$@"; do
  case "$arg" in
    --dry-run) DRY_RUN=1 ;;
    --force) FORCE=1 ;;
    *) echo "Unknown option: $arg" >&2; exit 1 ;;
  esac
done

command -v duti >/dev/null 2>&1 || {
  echo "Missing: duti (brew install duti)" >&2
  exit 1
}

IINA_APP="/Applications/IINA.app"
if [[ ! -d "$IINA_APP" ]]; then
  echo "Missing: $IINA_APP — brew install --cask iina" >&2
  exit 1
fi

BUNDLE_ID="$(/usr/libexec/PlistBuddy -c 'Print :CFBundleIdentifier' "$IINA_APP/Contents/Info.plist")"

# Extension → almost always video on macOS (do not assign to Neovim).
EXTENSIONS=(ts)

# UTIs for transport-stream / related (IINA handles playback).
UTIS=(
  public.mpeg-2-transport-stream
)

current_ext_handler() {
  duti -x "$1" 2>/dev/null | sed -n '3p' || true
}

current_uti_handler() {
  duti -d "$1" 2>/dev/null || true
}

defaults_already_set() {
  local ext uti current

  for uti in "${UTIS[@]}"; do
    [[ "$(current_uti_handler "$uti")" == "$BUNDLE_ID" ]] || return 1
  done
  current=$(current_ext_handler ts)
  [[ -z "$current" || "$current" == "$BUNDLE_ID" ]] || return 1
  return 0
}

run_duti() {
  local target=$1

  if (( DRY_RUN )); then
    printf 'duti -s %s %s all\n' "$BUNDLE_ID" "$target"
    return 0
  fi
  if ! duti -s "$BUNDLE_ID" "$target" all; then
    echo "  ! skipped: duti -s $BUNDLE_ID $target all" >&2
    return 0
  fi
  (( APPLIED++ )) || true
}

APPLIED=0
SKIPPED=0

echo "Bundle: $BUNDLE_ID ($IINA_APP)"
echo "(.ts = video on macOS; edit TypeScript with: nvim file.ts or .tsx in Finder)"
echo

if (( ! FORCE && ! DRY_RUN )) && defaults_already_set; then
  echo "Already set (IINA). Skipping duti — use --force to re-apply."
  exit 0
fi

for ext in "${EXTENSIONS[@]}"; do
  current=$(current_ext_handler "$ext")
  if (( ! FORCE )); then
    if [[ -z "$current" ]]; then
      (( SKIPPED++ )) || true
      continue
    fi
    if [[ "$current" == "$BUNDLE_ID" ]]; then
      (( SKIPPED++ )) || true
      continue
    fi
  fi
  run_duti "$ext"
done

for uti in "${UTIS[@]}"; do
  if (( ! FORCE )) && [[ "$(current_uti_handler "$uti")" == "$BUNDLE_ID" ]]; then
    (( SKIPPED++ )) || true
    continue
  fi
  run_duti "$uti"
done

if (( DRY_RUN )); then
  echo "(dry-run — no changes applied)"
elif (( APPLIED == 0 )); then
  echo "Already set ($SKIPPED handlers). Use --force to re-apply."
else
  echo "Updated $APPLIED handler(s). Double-click a .ts video to test with IINA."
fi
