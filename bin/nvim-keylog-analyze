#!/usr/bin/env python3
"""Analyze Neovim keystroke log (JSONL) for repetitive / wasteful patterns."""

from __future__ import annotations

import argparse
import json
import re
from collections import Counter, defaultdict
from pathlib import Path

DEFAULT_LOG = Path.home() / ".local/state/nvim-keylog.jsonl"

MOTION_KEYS = {"j", "k", "h", "l", "<Down>", "<Up>", "<Left>", "<Right>"}
LEADER_KEYS = {"<Space>", "<leader>", " "}


def load_events(path: Path) -> list[dict]:
    events: list[dict] = []
    if not path.is_file():
        return events
    with path.open(encoding="utf-8", errors="replace") as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                events.append(json.loads(line))
            except json.JSONDecodeError:
                continue
    return events


def pct(n: int, total: int) -> str:
    if total == 0:
        return "0%"
    return f"{100 * n / total:.1f}%"


def analyze(events: list[dict], top_n: int) -> str:
    if not events:
        return f"No events in log (keylog is on by default in standalone nvim).\n"

    keys = [e.get("key", "") for e in events]
    modes = Counter(e.get("mode", "?") for e in events)
    key_counts = Counter(keys)
    total = len(keys)

    lines: list[str] = []
    lines.append(f"Events: {total:,}")
    lines.append(f"Modes: {', '.join(f'{m}={c}' for m, c in modes.most_common())}")
    lines.append("")
    lines.append(f"Top {top_n} keys:")
    for key, count in key_counts.most_common(top_n):
        display = key if key != " " else "<Space>"
        lines.append(f"  {display:16} {count:6}  ({pct(count, total)})")

    motion = sum(key_counts.get(k, 0) for k in MOTION_KEYS)
    esc = key_counts.get("<Esc>", 0)
    leader = sum(key_counts.get(k, 0) for k in LEADER_KEYS)
    lines.append("")
    lines.append("Signals:")
    lines.append(f"  Motion keys (j/k/h/l/arrows): {motion} ({pct(motion, total)})")
    lines.append(f"  <Esc>:                        {esc} ({pct(esc, total)})")
    lines.append(f"  Leader (<Space>):             {leader} ({pct(leader, total)})")

    # Repeated same key 4+ times in a row
    streaks: Counter[str] = Counter()
    run_key, run_len = None, 0
    for k in keys:
        if k == run_key:
            run_len += 1
        else:
            if run_key and run_len >= 4:
                streaks[run_key] += 1
            run_key, run_len = k, 1
    if run_key and run_len >= 4:
        streaks[run_key] += 1
    if streaks:
        lines.append("")
        lines.append("Repeated key streaks (4+ in a row):")
        for k, c in streaks.most_common(8):
            display = k if k != " " else "<Space>"
            lines.append(f"  {display:16} {c} streak(s)")

    # Bigrams
    bigrams: Counter[tuple[str, str]] = Counter()
    for i in range(len(keys) - 1):
        bigrams[(keys[i], keys[i + 1])] += 1
    lines.append("")
    lines.append(f"Top {min(top_n, 12)} key pairs:")
    for (a, b), count in bigrams.most_common(min(top_n, 12)):
        da = a if a != " " else "<Space>"
        db = b if b != " " else "<Space>"
        lines.append(f"  {da} → {db:14} {count:5}")

    # Leader then Esc within 3 keys (aborted chord)
    aborted = 0
    for i in range(len(keys) - 1):
        if keys[i] in LEADER_KEYS and keys[i + 1] == "<Esc>":
            aborted += 1
    if leader:
        lines.append("")
        lines.append(f"Leader then <Esc> (aborted chord): {aborted}")

    # Per filetype churn
    by_ft: dict[str, list[str]] = defaultdict(list)
    for e in events:
        by_ft[e.get("ft", "")].append(e.get("key", ""))
    if len(by_ft) > 1:
        lines.append("")
        lines.append("Motion ratio by filetype:")
        for ft, ft_keys in sorted(by_ft.items(), key=lambda x: -len(x[1]))[:8]:
            if not ft:
                ft = "(no ft)"
            m = sum(1 for k in ft_keys if k in MOTION_KEYS)
            lines.append(f"  {ft:20} motion {pct(m, len(ft_keys))}  ({len(ft_keys)} keys)")

    lines.append("")
    lines.append("Tip: :NvimKeylogDisable to pause logging; :NvimKeylogAnalyze in nvim")
    return "\n".join(lines) + "\n"


def main() -> int:
    parser = argparse.ArgumentParser(description=__doc__)
    parser.add_argument(
        "log",
        nargs="?",
        type=Path,
        default=DEFAULT_LOG,
        help=f"JSONL log path (default: {DEFAULT_LOG})",
    )
    parser.add_argument("--top", type=int, default=15, help="Top N keys/pairs to show")
    parser.add_argument("--since", type=str, default=None, help="ISO date prefix filter (e.g. 2026-05-20)")
    args = parser.parse_args()

    events = load_events(args.log)
    if args.since:
        events = [e for e in events if e.get("ts", "").startswith(args.since)]

    print(analyze(events, args.top), end="")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
