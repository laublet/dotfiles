#!/usr/bin/env bash
# Bootstrap a fresh machine: install packages + link dotfiles.
# Usage:
#   macOS:  ./bootstrap
#   Linux:  ./bootstrap
#   Server: ./install-server  (minimal: vim, zsh, nvim, git, tmux)

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$BASEDIR"

OS="$(uname -s)"
echo "==> Bootstrapping on ${OS}..."

# ── Install packages ──────────────────────────────────────────────
if [[ "$OS" == "Darwin" ]]; then
  if ! command -v brew &>/dev/null; then
    echo "==> Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
  fi
  echo "==> Installing packages (Brewfile)..."
  brew bundle --file="$BASEDIR/Brewfile"

elif [[ "$OS" == "Linux" ]]; then
  echo "==> Installing packages (packages-linux.sh)..."
  bash "$BASEDIR/packages-linux.sh"
fi

# ── Install Prezto ────────────────────────────────────────────────
if [[ ! -d "${ZDOTDIR:-$HOME}/.zprezto" ]]; then
  echo "==> Installing Prezto..."
  git clone --recursive https://github.com/sorin-ionescu/prezto.git "${ZDOTDIR:-$HOME}/.zprezto"
fi

# ── Install fzf-tab (loaded as a prezto contrib module) ──────────
if [[ ! -d "${ZDOTDIR:-$HOME}/.zprezto/contrib/fzf-tab" ]]; then
  echo "==> Installing fzf-tab..."
  git clone https://github.com/Aloxaf/fzf-tab "${ZDOTDIR:-$HOME}/.zprezto/contrib/fzf-tab"
fi

# ── Link dotfiles ─────────────────────────────────────────────────
echo "==> Linking dotfiles..."
bash "$BASEDIR/install"

# ── macOS post-link (Neovim.app, duti, bob) ───────────────────────
if [[ "$OS" == "Darwin" ]]; then
  if command -v bob &>/dev/null && [[ ! -x "${HOME}/.local/share/bob/nvim-bin/nvim" ]]; then
    echo "==> Installing Neovim via bob (pin v0.11.x — see Brewfile)..."
    bob install v0.11.5 || bob install stable
  fi
fi

# ── Set default shell to zsh ─────────────────────────────────────
if [[ "$SHELL" != */zsh ]]; then
  echo "==> Setting zsh as default shell..."
  chsh -s "$(which zsh)"
fi

echo ""
if [[ "$OS" == "Darwin" ]]; then
  echo "==> macOS: text files open in Neovim if duti + Neovim.app are linked (just link / install-mac)."
  echo "    Re-apply handlers: mac-neovim-defaults"
fi
echo "==> Done! Restart your shell or run: exec zsh"
if [[ "$OS" == "Darwin" ]]; then
  echo ""
  echo "macOS extras (if not applied during install):"
  echo "  bob install v0.11.5     # if nvim missing (0.11 pin)"
  echo "  mac-neovim-defaults     # Finder default app for .json, .csv, … (needs duti)"
  echo "  nvim -c MasonToolsInstallAll   # Mason formatters (prettierd, prettier, stylua)"
fi
