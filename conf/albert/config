[General]
hotkey=Meta+Space
showTray=false
telemetry=false
enabled_plugins=applications, clipboard, calculator_qalculate, websearch, system, files, obsidian, homebrew, snippets, datetime, hash, ssh

[applications]
fuzzy_matching=true

[files]
fuzzy_matching=true

[websearch]
# Default search engines are provided by Albert

[widgetsboxmodel]
action_item_padding=6
action_item_selection_border_radius=11
alwaysOnTop=true
clearOnHide=true
disable_input_method=true
displayScrollbar=false
followCursor=true
hideOnFocusLoss=true
historySearch=true
input_border_radius=11
input_font_size=22
input_padding=5
itemCount=7
result_item_horizontal_spacing=6
result_item_icon_size=39
result_item_padding=6
result_item_selection_border_radius=11
result_item_subtext_font_size=12
result_item_text_font_size=17
result_item_vertical_spacing=2
showCentered=true
window_border_radius=18
window_border_width=1
window_padding=7
window_shadow_offset=8
window_shadow_size=80
window_spacing=7
window_width=640
