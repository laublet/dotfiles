    // ── perso / AeroSpace parity (native Super+Ctrl+Alt, no keyd) ──

    // LCAG — focus window (same fingers as macOS ctrl-cmd-alt + arrows)
    (modifiers: [Super, Ctrl, Alt], key: "Left"): Focus(Left),
    (modifiers: [Super, Ctrl, Alt], key: "Right"): Focus(Right),
    (modifiers: [Super, Ctrl, Alt], key: "Up"): Focus(Up),
    (modifiers: [Super, Ctrl, Alt], key: "Down"): Focus(Down),
    (modifiers: [Super, Ctrl, Alt], key: "h"): Focus(Left),
    (modifiers: [Super, Ctrl, Alt], key: "j"): Focus(Down),
    (modifiers: [Super, Ctrl, Alt], key: "k"): Focus(Up),
    (modifiers: [Super, Ctrl, Alt], key: "l"): Focus(Right),

    // HYPR — move window
    (modifiers: [Super, Ctrl, Alt, Shift], key: "Left"): Move(Left),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "Right"): Move(Right),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "Up"): Move(Up),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "Down"): Move(Down),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "h"): Move(Left),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "j"): Move(Down),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "k"): Move(Up),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "l"): Move(Right),

    // Cmd+Alt workspaces (physical Super+Alt) — macOS cmd-alt-0..9
    (modifiers: [Super, Alt], key: "0"): LastWorkspace,
    (modifiers: [Super, Alt], key: "1"): Workspace(1),
    (modifiers: [Super, Alt], key: "2"): Workspace(2),
    (modifiers: [Super, Alt], key: "3"): Workspace(3),
    (modifiers: [Super, Alt], key: "4"): Workspace(4),
    (modifiers: [Super, Alt], key: "5"): Workspace(5),
    (modifiers: [Super, Alt], key: "6"): Workspace(6),
    (modifiers: [Super, Alt], key: "7"): Workspace(7),
    (modifiers: [Super, Alt], key: "8"): Workspace(8),
    (modifiers: [Super, Alt], key: "9"): Workspace(9),

    // Workspace prev/next (macOS cmd-alt left/right → perso uses up/down on Linux)
    (modifiers: [Super, Alt], key: "Up"): PreviousWorkspace,
    (modifiers: [Super, Alt], key: "Down"): NextWorkspace,

    (modifiers: [Ctrl], key: "q"): Close,
    (modifiers: [Ctrl, Shift], key: "v"): Spawn("clipboard-rofi"),
    (modifiers: [Super], key: "Return"): Spawn("wezterm"),
    (modifiers: [Super, Shift], key: "Return"): Spawn("cursor"),

    // Monitors (macOS cmd-alt left/right)
    (modifiers: [Super, Alt], key: "Left"): SwitchOutput(Left),
    (modifiers: [Super, Alt], key: "Right"): SwitchOutput(Right),
    (modifiers: [Super, Alt, Shift], key: "Left"): MoveToOutput(Left),
    (modifiers: [Super, Alt, Shift], key: "Right"): MoveToOutput(Right),
