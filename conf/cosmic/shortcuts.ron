// COSMIC custom shortcuts — overrides only (WM uses system defaults + keyd remap).
//
// keyd translates physical AeroSpace chords → COSMIC default Super chords.
// See conf/keyd/default.conf and /usr/share/cosmic/.../Shortcuts/v1/defaults
//
// Deployed: ~/.config/cosmic/com.system76.CosmicSettings.Shortcuts/v1/custom

{
    // Cmd+Q → Ctrl+Q via keyd
    (modifiers: [Ctrl], key: "q"): Close,

    // Cmd+Shift+V → Ctrl+Shift+V via keyd
    (modifiers: [Ctrl, Shift], key: "v"): Spawn("clipboard-rofi"),

    // LCAG+Return / HYPR+Return — not COSMIC defaults
    (modifiers: [Super, Ctrl, Alt], key: "Return"): Spawn("wezterm"),
    (modifiers: [Super, Ctrl, Alt, Shift], key: "Return"): Spawn("cursor"),
}
