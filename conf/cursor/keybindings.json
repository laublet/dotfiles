// https://code.visualstudio.com/docs/getstarted/keybindings
// Cursor keybindings v6 — Loïc
// Architecture (modifier escalation, consistent with/without splits):
//   Zone navigation     → Ctrl + arrows (always: sidebar ← editor → chat, terminal ↕ editor)
//                          Escape from any zone → editor (only way out of chat: webview limitation)
//   Split navigation    → Ctrl + Shift + arrows (editor groups + terminal panes)
//   Move editor groups  → Ctrl + Alt + arrows (same chord as WezTerm/Neovim resize)
//   Tab switching       → Cmd + Shift + left/right (editor tabs, terminal instances, chat tabs)
//   Tab reorder         → Cmd + Alt + left/right
//   Split creation      → Cmd+d / Cmd+Shift+d (context-aware: editor or terminal)
//   Terminal mgmt       → Cmd+t (new), Cmd+w (kill), Cmd+d (split) — when terminal focused
//   Leader layer        → Space + key (via vscode-neovim, from editor normal mode)
//     Space+e  explorer   Space+f  quick open    Space+g  find in files
//     Space+t  terminal   Space+v  git (scm)     Space+c  AI chat
//     Space+b  buffers    Space+d  debugger      Space+w  save
//     Space+q  close      Space+z  zen mode
//   AI accept/reject    → Cmd+Enter (inline chat), Cmd+Shift+Enter (accept diff/tool),
//                          Cmd+Shift+Backspace (reject), Cmd+Ctrl+Enter/Backspace (bulk)
//
// Spatial model:
//   [Sidebar] ←Ctrl+Left— [Editor] —Ctrl+Right→ [AI Chat]
//                            ↕ Ctrl+Down / Ctrl+Up
//                         [Terminal]
//
// Webview limitation: Cmd+Shift+arrows and Ctrl+Left do NOT work inside the
// AI chat panel (webview captures keys at DOM level). Use Escape to exit chat.
//
// Chat / Composer input field: Shift+Enter inserts a newline; Enter sends the message.
// If that does not match your build, open Keyboard Shortcuts and search for "newline"
// or "chat" (exact command ids change between Cursor versions — not duplicated here).
//
// CHANGE v6: Terminal management (split, kill, new, navigate panes/instances).
//   Cmd+d/w/t context-aware: editor vs terminal. Same keys as WezTerm.
// CHANGE v5: Ctrl+arrows always = zone nav (consistent with/without splits).
//   Ctrl+Shift+arrows = split nav. Tab reorder moved to Cmd+Alt.
// CHANGE v4: Ctrl+arrows now works from ALL zones (terminal, sidebar, panel, AI).
// CHANGE v3: Ctrl+arrows replaces Ctrl+w+arrows for split focus.
[
  // =========================================================================
  // Zone navigation — Ctrl + arrows (always, with or without splits)
  // =========================================================================
  // Editor → zones
  {
    "key": "ctrl+left",
    "command": "workbench.action.focusSideBar",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+right",
    "command": "workbench.action.focusAuxiliaryBar",
    "when": "editorTextFocus"
  },
  {
    "key": "ctrl+down",
    "command": "workbench.action.terminal.focus",
    "when": "editorTextFocus"
  },

  // From sidebar → editor (Ctrl+Right = go right to editor, Escape = back)
  // Use broad OR to cover all sidebar views (explorer tree, search, SCM, etc.)
  {
    "key": "ctrl+right",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "sideBarFocus || filesExplorerFocus || sideBarVisible && !editorTextFocus && !terminalFocus && !auxiliaryBarFocus && !panelFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "(sideBarFocus || filesExplorerFocus) && !inputFocus"
  },

  // From terminal → editor (terminal is below, so Ctrl+Up = go up to editor)
  {
    "key": "ctrl+up",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "terminalFocus && !terminalTextInputFocus"
  },

  // From panel (output, problems, etc.) → editor
  {
    "key": "ctrl+up",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "panelFocus && !terminalFocus"
  },

  // From auxiliary bar / AI chat → editor
  // NOTE: Ctrl+Left does NOT work from the chat (webview captures keys at DOM level).
  // Escape is the only reliable way to leave the chat.
  {
    "key": "escape",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "auxiliaryBarFocus && !inputFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.focusActiveEditorGroup",
    "when": "inChat && !editorTextFocus && !inputFocus"
  },

  // =========================================================================
  // Move editor group — Ctrl + Alt + arrows (adjacent modifiers on Kyria)
  // =========================================================================
  {
    "key": "ctrl+alt+left",
    "command": "workbench.action.moveActiveEditorGroupLeft"
  },
  {
    "key": "ctrl+alt+right",
    "command": "workbench.action.moveActiveEditorGroupRight"
  },
  {
    "key": "ctrl+alt+up",
    "command": "workbench.action.moveActiveEditorGroupUp"
  },
  {
    "key": "ctrl+alt+down",
    "command": "workbench.action.moveActiveEditorGroupDown"
  },

  // =========================================================================
  // Split navigation — Ctrl + Shift + arrows (between editor groups)
  // =========================================================================
  {
    "key": "ctrl+shift+left",
    "command": "workbench.action.focusLeftGroup"
  },
  {
    "key": "ctrl+shift+right",
    "command": "workbench.action.focusRightGroup"
  },
  {
    "key": "ctrl+shift+up",
    "command": "workbench.action.focusAboveGroup"
  },
  {
    "key": "ctrl+shift+down",
    "command": "workbench.action.focusBelowGroup"
  },

  // =========================================================================
  // Tab switching — Cmd + Shift + left/right (same as WezTerm)
  // =========================================================================
  // Editor tabs
  {
    "key": "cmd+shift+left",
    "command": "workbench.action.previousEditor"
  },
  {
    "key": "cmd+shift+right",
    "command": "workbench.action.nextEditor"
  },
  // Chat tabs (conversations) — same keys, active when in chat
  {
    "key": "cmd+shift+left",
    "command": "composer.selectPreviousComposer",
    "when": "inChat && !editorTextFocus"
  },
  {
    "key": "cmd+shift+right",
    "command": "composer.selectNextComposer",
    "when": "inChat && !editorTextFocus"
  },

  // =========================================================================
  // Reorder tabs within group — Cmd + Alt + left/right
  // =========================================================================
  {
    "key": "cmd+alt+left",
    "command": "workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "cmd+alt+right",
    "command": "workbench.action.moveEditorRightInGroup"
  },

  // =========================================================================
  // Split creation — Cmd+d / Cmd+Shift+d (same as WezTerm, context-aware)
  // =========================================================================
  // Editor splits
  {
    "key": "cmd+d",
    "command": "workbench.action.splitEditor",
    "when": "editorFocus"
  },
  {
    "key": "cmd+d",
    "command": "-editor.action.addSelectionToNextFindMatch"
  },
  {
    "key": "cmd+shift+d",
    "command": "workbench.action.splitEditorDown",
    "when": "editorFocus"
  },
  // Terminal splits
  {
    "key": "cmd+d",
    "command": "workbench.action.terminal.split",
    "when": "terminalFocus"
  },

  // =========================================================================
  // Terminal management — same keys as WezTerm when in terminal
  // =========================================================================
  // New terminal instance (Cmd+t, like WezTerm new tab)
  {
    "key": "cmd+t",
    "command": "workbench.action.terminal.new",
    "when": "terminalFocus"
  },
  // Kill terminal (Cmd+w, like WezTerm close pane)
  {
    "key": "cmd+w",
    "command": "workbench.action.terminal.kill",
    "when": "terminalFocus"
  },
  // Navigate split terminal panes (Ctrl+Shift, same tier as editor split nav)
  {
    "key": "ctrl+shift+left",
    "command": "workbench.action.terminal.focusPreviousPane",
    "when": "terminalFocus"
  },
  {
    "key": "ctrl+shift+right",
    "command": "workbench.action.terminal.focusNextPane",
    "when": "terminalFocus"
  },
  // Switch terminal instances (Cmd+Shift, same tier as editor tab switching)
  {
    "key": "cmd+shift+left",
    "command": "workbench.action.terminal.focusPrevious",
    "when": "terminalFocus"
  },
  {
    "key": "cmd+shift+right",
    "command": "workbench.action.terminal.focusNext",
    "when": "terminalFocus"
  },

  // =========================================================================
  // Cursor AI — accept / reject
  // =========================================================================
  // Inline chat (Cmd+K): accept changes
  {
    "key": "cmd+enter",
    "command": "inlineChat.acceptChanges",
    "when": "inlineChatVisible"
  },
  // Chat-applied diffs: accept / reject current file
  {
    "key": "cmd+shift+enter",
    "command": "chatEditor.action.accept",
    "when": "inChat && hasChatEdits"
  },
  {
    "key": "cmd+shift+backspace",
    "command": "chatEditor.action.reject",
    "when": "inChat && hasChatEdits"
  },
  // Bulk: accept / reject ALL AI-edited files
  {
    "key": "cmd+ctrl+enter",
    "command": "chatEditing.acceptAllFiles",
    "when": "inChat"
  },
  {
    "key": "cmd+ctrl+backspace",
    "command": "chatEditing.discardAllFiles",
    "when": "inChat"
  },
  // Agent mode: accept tool call (terminal command approval)
  {
    "key": "cmd+shift+enter",
    "command": "workbench.action.chat.acceptTool",
    "when": "inChat && chatRequestHasTool"
  },
  // Agent mode: cancel terminal tool call
  {
    "key": "cmd+shift+backspace",
    "command": "composer.cancelTerminalToolCall",
    "when": "inChat && chatRequestHasTool"
  },

  // =========================================================================
  // Cursor AI — voice chat
  // =========================================================================
  {
    "key": "cmd+u",
    "command": "workbench.action.chat.startVoiceChat",
    "when": "!voiceChatInProgress"
  },
  {
    "key": "cmd+u",
    "command": "workbench.action.chat.stopListeningAndSubmit",
    "when": "voiceChatInProgress"
  },

  // =========================================================================
  // Disable conflicting defaults
  // =========================================================================
  // Ctrl+arrows freed from vscode-neovim via ctrlKeysForNormalMode in settings.json.
  // Disable default Ctrl+Up/Down scroll (conflicts with zone/split nav)
  {
    "key": "ctrl+up",
    "command": "-scrollLineUp"
  },
  {
    "key": "ctrl+down",
    "command": "-scrollLineDown"
  },
  // Disable Ctrl+w+arrows from vscode-neovim (replaced by Ctrl+arrows above)
  {
    "key": "ctrl+w ctrl+left",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w ctrl+right",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w ctrl+up",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w ctrl+down",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w left",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w right",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w up",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w down",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  // Also disable Ctrl+w h/j/k/l to be safe
  {
    "key": "ctrl+w h",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w j",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w k",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },
  {
    "key": "ctrl+w l",
    "command": "-vscode-neovim.send",
    "when": "editorTextFocus && neovim.init"
  },

  // Disable old Cmd+K chord defaults
  {
    "key": "cmd+k cmd+left",
    "command": "-workbench.action.focusLeftGroup"
  },
  {
    "key": "cmd+k cmd+right",
    "command": "-workbench.action.focusRightGroup"
  },
  {
    "key": "cmd+k cmd+up",
    "command": "-workbench.action.focusAboveGroup"
  },
  {
    "key": "cmd+k cmd+down",
    "command": "-workbench.action.focusBelowGroup"
  },
  {
    "key": "cmd+k left",
    "command": "-workbench.action.moveActiveEditorGroupLeft"
  },
  {
    "key": "cmd+k right",
    "command": "-workbench.action.moveActiveEditorGroupRight"
  },
  {
    "key": "cmd+k up",
    "command": "-workbench.action.moveActiveEditorGroupUp"
  },
  {
    "key": "cmd+k down",
    "command": "-workbench.action.moveActiveEditorGroupDown"
  },
  {
    "key": "cmd+k shift+cmd+left",
    "command": "-workbench.action.moveEditorLeftInGroup"
  },
  {
    "key": "cmd+k shift+cmd+right",
    "command": "-workbench.action.moveEditorRightInGroup"
  },
  {
    "key": "shift+f12",
    "command": "-editor.action.goToReferences",
    "when": "editorHasReferenceProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
  },
  {
    "key": "alt+f12",
    "command": "-editor.action.peekDefinition",
    "when": "editorHasDefinitionProvider && editorTextFocus && !inReferenceSearchEditor && !isInEmbeddedEditor"
  },

  // =========================================================================
  // Linux: Alt+arrows = word navigation (macOS Option+arrows, native on Mac)
  // keyd handles this at system level for GTK/Qt, but Cursor/Electron needs
  // explicit bindings since keyd's alt_override sends Ctrl+arrows which
  // would conflict with split navigation in the editor.
  // =========================================================================
  {
    "key": "alt+left",
    "command": "cursorWordLeft",
    "when": "editorTextFocus && isLinux"
  },
  {
    "key": "alt+right",
    "command": "cursorWordRight",
    "when": "editorTextFocus && isLinux"
  },
  {
    "key": "alt+shift+left",
    "command": "cursorWordLeftSelect",
    "when": "editorTextFocus && isLinux"
  },
  {
    "key": "alt+shift+right",
    "command": "cursorWordRightSelect",
    "when": "editorTextFocus && isLinux"
  },
  {
    "key": "alt+backspace",
    "command": "deleteWordLeft",
    "when": "editorTextFocus && isLinux"
  }
]
