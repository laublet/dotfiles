{
  // =========================================================================
  // Editor — General
  // =========================================================================
  "editor.tabSize": 2,
  "editor.formatOnSave": true,
  "editor.inlineSuggest.enabled": true,
  "editor.accessibilitySupport": "off",
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit",
    "source.fixAll": "explicit",
    "source.addMissingImports": "explicit"
  },
  "files.autoSave": "afterDelay",

  // =========================================================================
  // Editor — Appearance
  // =========================================================================
  "workbench.colorTheme": "Dracula Theme",
  "workbench.preferredDarkColorTheme": "Dracula Theme",
  "workbench.preferredHighContrastColorTheme": "Dracula Theme",
  "window.commandCenter": 1,
  "editor.fontLigatures": true,
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontSize": 16,
  "editor.codeLensFontFamily": "FiraCode Nerd Font",
  "workbench.settings.applyToAllProfiles": ["editor.fontFamily"],

  // =========================================================================
  // Editor — Formatters
  // =========================================================================
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "diffEditor.ignoreTrimWhitespace": true
  },

  // =========================================================================
  // TypeScript / JavaScript
  // =========================================================================
  "javascript.updateImportsOnFileMove.enabled": "always",
  "typescript.updateImportsOnFileMove.enabled": "always",

  // =========================================================================
  // Explorer
  // =========================================================================
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },

  // =========================================================================
  // Git
  // =========================================================================
  "git.suggestSmartCommit": false,
  "diffEditor.ignoreTrimWhitespace": false,

  // =========================================================================
  // Security
  // =========================================================================
  "security.workspace.trust.untrustedFiles": "open",

  // =========================================================================
  // Cursor (AI features)
  // =========================================================================
  "cursor.chat.premiumChatAutoScrollWhenAtBottom": true,
  "cursor.chat.showSuggestedFiles": true,
  "cursor.chat.showPremiumChatHistory": false,
  "cursor.cpp.enablePartialAccepts": true,

  // =========================================================================
  // Coverage
  // =========================================================================
  "coverage-gutters.coverageFileNames": [
    "cobertura-coverage.xml",
    "lcov.info",
    "cov.xml",
    "coverage.xml",
    "jacoco.xml",
    "coverage.cobertura.xml"
  ],

  // =========================================================================
  // vscode-neovim
  // =========================================================================
  // Extension: asvetliakov.vscode-neovim
  // All vim keybindings live in ~/.config/nvim/init.lua (shared with standalone)
  // Leader layer, LSP bindings (gd/gi/gr/gh), surround, comment —
  // all handled by Neovim, NOT by VSCode settings.
  "extensions.experimental.affinity": {
    "asvetliakov.vscode-neovim": 1
  },
  "editor.lineNumbers": "relative",
  "workbench.statusBar.visible": false,

  // =========================================================================
  // GitLens
  // =========================================================================
  "gitlens.plusFeatures.enabled": false
}
