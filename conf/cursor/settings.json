{
    "window.commandCenter": 1,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.inlineSuggest.enabled": true,
    "editor.tabSize": 2,
    // "editor.defaultFormatter": "dbaeumer.vscode-eslint",
    // "editor.defaultFormatter": "rvest.vs-code-prettier-eslint",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit",
        "source.fixAll": "explicit",
        "source.addMissingImports": "explicit",
    },
    "explorer.confirmDelete": false,
    "explorer.confirmDragAndDrop": false,
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[yaml]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "diffEditor.ignoreTrimWhitespace": true
    },
    "javascript.updateImportsOnFileMove.enabled": "always",
    "typescript.updateImportsOnFileMove.enabled": "always",
    "git.suggestSmartCommit": false,
    "security.workspace.trust.untrustedFiles": "open",
    "vim.useSystemClipboard": true,
    "vim.vimrc.enable": true,
    "vim.insertModeKeyBindings": [
        {
        "before": ["g", "i"],
        "commands": ["editor.action.goToImplementation"]
        },
        {
        "before": ["g", "r"],
        "commands": ["editor.action.goToReferences"]
        }
    ],
    "vim.normalModeKeyBindings": [
        {
        "before": ["g", "i"],
        "commands": ["editor.action.goToImplementation"]
        },
        {
        "before": ["g", "r"],
        "commands": ["editor.action.goToReferences"]
        }
    ],
    "workbench.colorTheme": "Dracula Theme",
    "coverage-gutters.coverageFileNames": [
        "cobertura-coverage.xml",
        "lcov.info",
        "cov.xml",
        "coverage.xml",
        "jacoco.xml",
        "coverage.cobertura.xml"
    ],
    "cursor.chat.premiumChatAutoScrollWhenAtBottom": true,
    "cursor.chat.showSuggestedFiles": true,
    "cursor.chat.showPremiumChatHistory": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*",
        "*.sqlite3": "${capture}.${extname}-*",
        "*.db3": "${capture}.${extname}-*",
        "*.sdb": "${capture}.${extname}-*",
        "*.s3db": "${capture}.${extname}-*"
    },
    "editor.fontFamily": "Hack Nerd Font",
    "editor.fontSize": 16,
    "editor.codeLensFontFamily": "Hack Nerd Font",
    "workbench.settings.applyToAllProfiles": [
        "editor.fontFamily"
    ],
    "workbench.preferredDarkColorTheme": "Dracula Theme",
    "workbench.preferredHighContrastColorTheme": "Dracula Theme",
    "vim.smartRelativeLine": true,
    "editor.accessibilitySupport": "off",
    "cursor.cpp.enablePartialAccepts": true,
    "files.autoSave": "afterDelay",
}