# Ghostty lab — thin emulator for Zellij (WezTerm remains main mux).
# Launch: ghostty-lab  |  Config: conf/ghostty/config → ~/.config/ghostty/config

theme = Dracula
font-family = FiraCode Nerd Font
font-size = 16
font-thicken = true

window-padding-x = 8
window-padding-y = 8
background-opacity = 1.0

macos-option-as-alt = true
shell-integration = zsh
quit-after-last-window-closed = true

# OSC 133 from zsh (_osc133_* in zshrc) + Ghostty shell-integration.
notify-on-command-finish = unfocused
notify-on-command-finish-action = bell,notify
notify-on-command-finish-after = 3s

# Zellij owns splits/tabs — disable Ghostty native mux keybinds.
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
keybind = cmd+shift+enter=unbind
keybind = cmd+t=unbind
keybind = cmd+n=unbind
keybind = cmd+w=unbind
keybind = cmd+shift+w=unbind
keybind = cmd+shift+left=unbind
keybind = cmd+shift+right=unbind
keybind = cmd+alt+left=unbind
keybind = cmd+alt+right=unbind
