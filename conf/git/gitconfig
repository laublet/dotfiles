[includeIf "gitdir:~/dev/perso/**"]
    path = ~/dev/perso/.gitconfig-perso
[includeIf "gitdir:~/dev/work/**"]
    path = ~/dev/work/.gitconfig-work
[core]
	editor = nvim
	excludesFile = ~/.gitignore
	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true
	side-by-side = true
	line-numbers = true
	syntax-theme = Dracula
[merge]
	tool = fugitive
	conflictstyle = zdiff3
[mergetool "fugitive"]
	cmd = nvim -f -c \"Gvdiff\" \"$MERGED\":
[diff]
	colorMoved = default
[alias]
	# Structural diff via difftastic (AST-aware). Doesn't replace `git diff`
	# (delta-powered) — invoke explicitly: `git dft HEAD~1`, `git dft --staged`.
	dft = -c diff.external=difft diff
