Include ~/.ssh/hosts

Host github.com
  AddKeysToAgent yes
  UseKeychain yes
  IdentityFile ~/.ssh/github_perso

Host gitlab.com
  PreferredAuthentications publickey
  IdentityFile ~/.ssh/gitlab_pro

Host codeberg.org
  HostName codeberg.org
  User git
  IdentityFile ~/.ssh/codeberg_ed25519
  IdentitiesOnly yes
