# Dracula palette — source of truth for mac-appearance, borders, docs.
# Shell: source "$HOME/dev/perso/dotfiles/conf/theme/dracula.env"

DRACULA_BG="#282a36"
DRACULA_CURRENT="#44475a"
DRACULA_FG="#f8f8f2"
DRACULA_COMMENT="#6272a4"
DRACULA_CYAN="#8be9fd"
DRACULA_GREEN="#50fa7b"
DRACULA_ORANGE="#ffb86c"
DRACULA_PINK="#ff79c6"
DRACULA_PURPLE="#bd93f9"
DRACULA_RED="#ff5555"
DRACULA_YELLOW="#f1fa8c"

# Active desktop wallpaper (user pick; not committed as binary)
WALLPAPER="${HOME}/Pictures/wallpapers/dracula-ship-4k.png"

# macOS system accent: 5 = purple (Apple picker; not exact hex)
DRACULA_APPLE_ACCENT=5

# JankyBorders (ARGB 0xAARRGGBB) — active window: purple → pink
DRACULA_BORDERS_ACTIVE_GRADIENT='gradient(top_left=0xffbd93f9,bottom_right=0xffff79c6)'
DRACULA_BORDERS_INACTIVE_COLOR='0xff6272a4'
DRACULA_BORDERS_WIDTH='6.0'
