" https://github.com/tridactyl/tridactyl
" Tridactyl config — Loïc
" Coherent with Kyria / Neovim / WezTerm / Cursor workflow
"
" PAUSED 2026-05: Firefox uses Vimium; extension disabled (YouTube pain).
" Config kept for dotbot + possible re-enable. See cheatsheets/tridactyl.md (Status).
" Future: Tridactyl default + Vimium/Vimium C on backup sites via superignore — not active.
"
" Install native messenger first:  :installnative
" Then config auto-loads on Firefox start.
" Manual reload:  :source

" ── Reset ────────────────────────────────────────────────────────
sanitise tridactyllocal tridactylsync

" ── General ──────────────────────────────────────────────────────
set configpath ~/.config/tridactyl/tridactylrc
set smoothscroll true
set newtab about:blank
set editorcmd wezterm start -- nvim %f
set searchengine google

" ── Hint characters (home row only → fast 2-char combos) ─────────
" 9 chars = 81 combos with 2 keys, enough for most pages.
" All on Kyria home row — zero reach.
set hintchars asdfghjkl

" ── Tab navigation (J/K like vim buffers) ────────────────────────
bind J tabprev
bind K tabnext
bind gJ tabmove -1
bind gK tabmove +1

" d/u already close/undo-close tab (defaults)

" ── Scrolling (vim defaults, nothing to change) ──────────────────
" j/k = scroll down/up     h/l = scroll left/right
" gg/G = top/bottom         Ctrl-d/u = half-page down/up
" Ctrl-f/b = full page down/up

" ── History (vim-like) ───────────────────────────────────────────
" H/L already = back/forward (defaults)

" ── Hints ────────────────────────────────────────────────────────
" f = open link             F = open link in new tab
" ;y = yank link URL        ;p = copy element text
" ;i = open image           ;I = open image in new tab
" ;s = save link            ;S = save as...

" ── Quick marks (gX = open, gnX = new tab) ───────────────────────
quickmark g https://github.com
quickmark m https://mail.google.com
quickmark c https://calendar.google.com
quickmark t https://todoist.com
quickmark y https://youtube.com
quickmark o obsidian://open?vault=Main

" ── Search shortcuts (:open gh <query>) ──────────────────────────
set searchurls.gh https://github.com/search?q=%s&type=repositories
set searchurls.mdn https://developer.mozilla.org/en-US/search?q=%s
set searchurls.npm https://www.npmjs.com/search?q=%s
set searchurls.crates https://crates.io/search?q=%s
set searchurls.yt https://www.youtube.com/results?search_query=%s
set searchurls.w https://en.wikipedia.org/wiki/Special:Search/%s
set searchurls.rs https://doc.rust-lang.org/std/?search=%s

" ── Input mode ───────────────────────────────────────────────────
" Ctrl+[ = Escape (vim habit)
bind --mode=insert <C-[> composite unfocus | mode normal
" gi = focus first input (default)

" ── Obsidian Web Clipper ────────────────────────────────────────
" ;o = trigger Obsidian Web Clipper (extension must be installed)
bind ;o js document.querySelector('#obsidian-web-clipper-button')?.click() || browser.runtime.sendMessage("clipper@obsidian.md", {action: "clip"})

" ── Passthrough (sites with their own keyboard shortcuts) ────────
autocmd DocStart mail.google.com mode ignore
autocmd DocStart docs.google.com mode ignore
autocmd DocStart sheets.google.com mode ignore
autocmd DocStart slides.google.com mode ignore
autocmd DocStart calendar.google.com mode ignore
autocmd DocStart notion.so mode ignore
autocmd DocStart figma.com mode ignore
autocmd DocStart excalidraw.com mode ignore
autocmd DocStart todoist.com mode ignore

" ── YouTube ─────────────────────────────────────────────────────
" Mode ignore + bindings tridactyl sélectifs
" Toutes les touches non bindées passent à YouTube (< > j k space etc.)
" DocStart = chargement initial; UriChange = navigations SPA (sans reload) sinon
" mode ignore ne se réapplique pas → g/F captés par Tridactyl au lieu de la page
autocmd DocStart youtube.com mode ignore
autocmd UriChange youtube.com mode ignore

" Garder les commandes tridactyl utiles en mode ignore sur YouTube
" Majuscules et préfixes pour éviter conflits avec champs de texte
bindurl youtube.com --mode=ignore ;f hint
bindurl youtube.com --mode=ignore ;F hint -t
bindurl youtube.com --mode=ignore J tabprev
bindurl youtube.com --mode=ignore K tabnext
bindurl youtube.com --mode=ignore H back
bindurl youtube.com --mode=ignore L forward
bindurl youtube.com --mode=ignore D tabclose
bindurl youtube.com --mode=ignore U undo
bindurl youtube.com --mode=ignore gg scrollto 0
bindurl youtube.com --mode=ignore G scrollto 100
bindurl youtube.com --mode=ignore : fillcmdline_notrail
bindurl youtube.com --mode=ignore yy clipboard yank

" ── Theme ────────────────────────────────────────────────────────
colourscheme dark
