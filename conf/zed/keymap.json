// https://zed.dev/docs/key-bindings
// Zed keymap v2 — Loïc
// Mirrors Neovim leader layout (see conf/nvim/lua/plugins/which-key.lua):
//   space p* find files       space f* grep / search
//   space g* git              space h* git hunks
//   space l* lsp + format     space a* AI agent
//   space s/S symbols         space r recent
//   space e explorer          space b buffers
//   space t terminal          space d debugger
//   space v command palette   space c :noh (clear search hl)
//   space w save              space q close
//   space z centered          space \ / -  splits
//
// Discovery: which-key popup auto-shows after `space` is pressed (Zed ≥ Dec 2025).
// `dev: open key context view` (cmd palette) shows the active context tree.
// `zed: open default keymap` shows all defaults you may want to override.
[
  // =========================================================================
  // Pane / dock navigation — Ctrl + arrows (works editor ↔ docks ↔ splits)
  // =========================================================================
  {
    "bindings": {
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-right": "workspace::ActivatePaneRight",
      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-down": "workspace::ActivatePaneDown"
    }
  },

  // =========================================================================
  // Tab switching — Cmd + Shift + left/right
  // =========================================================================
  {
    "context": "Pane",
    "bindings": {
      "cmd-shift-left": "pane::ActivatePreviousItem",
      "cmd-shift-right": "pane::ActivateNextItem"
    }
  },

  // =========================================================================
  // Tab reorder within group — Cmd + Alt + left/right
  // =========================================================================
  {
    "context": "Pane",
    "bindings": {
      "cmd-alt-left": "pane::SwapItemLeft",
      "cmd-alt-right": "pane::SwapItemRight"
    }
  },

  // =========================================================================
  // Splits — Cmd+d (down) / Cmd+Shift+d (right) — same as WezTerm semantics
  // =========================================================================
  {
    "context": "Editor",
    "bindings": {
      "cmd-d": "pane::SplitDown",
      "cmd-shift-d": "pane::SplitRight"
    }
  },

  // =========================================================================
  // Save — Ctrl+S (Cmd+S handled by Cursor base keymap)
  // =========================================================================
  {
    "bindings": {
      "ctrl-s": "workspace::Save"
    }
  },

  // =========================================================================
  // Vim normal mode — leader layer (Space + key) — mirrors Neovim
  // =========================================================================
  {
    "context": "Editor && vim_mode == normal && !VimWaiting && !menu",
    "bindings": {
      // ---- Files & navigation (mirror nvim <leader>p* and <leader>r/e/b) ----
      "space p p": "file_finder::Toggle",
      "space p r": "projects::OpenRecent",
      "space r": "file_finder::Toggle",
      "space b": "tab_switcher::Toggle",
      "space e": "project_panel::ToggleFocus",
      "space E": "pane::RevealInProjectPanel",

      // ---- Grep / search (mirror nvim <leader>f*) ----
      // Zed has a single project search panel; toggles (case, regex, word, etc.)
      // live inside the panel: Alt+Cmd+C / W / X — see cheatsheets/zed.md.
      "space f f": "pane::DeploySearch",
      "space f /": "buffer_search::Deploy",
      "space /": "buffer_search::Deploy",

      // ---- Git (mirror nvim <leader>g*) ----
      "space g g": "git_panel::ToggleFocus",
      "space g s": "git_panel::ToggleFocus",
      "space g b": "git::Branches",
      "space g d": "git::Diff",

      // ---- Git hunks (mirror nvim <leader>h*) ----
      "space h s": "git::StageAndNext",
      "space h r": "git::Restore",
      "space h u": "git::Restore",
      "space h S": "git::StageAll",
      "space h R": "git::RestoreFile",
      "space h b": "editor::ToggleGitBlame",
      "space h B": "git::Blame",
      "space h d": "git::Diff",
      "space h n": "editor::GoToHunk",
      "space h N": "editor::GoToPreviousHunk",
      "space h p": "editor::ExpandAllDiffHunks",

      // ---- LSP / format (mirror nvim <leader>l*) ----
      "space l a": "editor::ToggleCodeActions",
      "space l f": "editor::Format",
      "space l r": "editor::Rename",

      // ---- Symbols (mirror nvim <leader>s/S) ----
      "space s": "outline::Toggle",
      "space S": "project_symbols::Toggle",

      // ---- AI agent (mirror nvim <leader>a* avante prefix) ----
      "space a a": "agent::ToggleFocus",
      "space a t": "agent::ToggleFocus",
      "space a n": "agent::NewThread",

      // ---- Clear search highlight (mirror nvim <leader>c → :noh) ----
      "space c": ["workspace::SendKeystrokes", ": n o h enter"],

      // ---- Panels ----
      "space t": "terminal_panel::ToggleFocus",
      "space d": "debug_panel::ToggleFocus",
      "space v": "command_palette::Toggle",

      // ---- Actions ----
      "space w": "workspace::Save",
      "space q": "pane::CloseActiveItem",
      "space z": "workspace::ToggleCenteredLayout",

      // ---- Splits (mirror nvim <leader>| / <leader>-) ----
      "space \\": "pane::SplitRight",
      "space -": "pane::SplitDown",

      // ---- Help / discovery (mirror nvim <leader>? / <leader>:) ----
      "space ?": "command_palette::Toggle",
      "space :": "command_palette::Toggle"
    }
  },

  // =========================================================================
  // Vim — empty pane fallback (so leader still works when no editor is open)
  // =========================================================================
  {
    "context": "EmptyPane || SharedScreen",
    "bindings": {
      "space e": "project_panel::ToggleFocus",
      "space p p": "file_finder::Toggle",
      "space f f": "pane::DeploySearch",
      "space t": "terminal_panel::ToggleFocus",
      "space g g": "git_panel::ToggleFocus",
      "space a a": "agent::ToggleFocus",
      "space v": "command_palette::Toggle"
    }
  },

  // =========================================================================
  // Vim — LSP shortcuts (g r / g i / g t aliases) — mirror Neovim LSP attach
  // Zed defaults already bind: g d (def), g h (hover), g s (doc symbols),
  // g S (workspace symbols), g . (code actions), c d (rename), [d / ]d (diag).
  // =========================================================================
  {
    "context": "Editor && vim_mode == normal && !VimWaiting",
    "bindings": {
      "g r": "editor::FindAllReferences",
      "g i": "editor::GoToImplementation",
      "g t": "editor::GoToTypeDefinition"
    }
  },

  // =========================================================================
  // AI agent — accept / reject edits (Zed AgentDiff context)
  // Action names verified against assets/keymaps/default-macos.json.
  // =========================================================================
  {
    "context": "AgentDiff",
    "bindings": {
      "cmd-shift-enter": "agent::KeepAll",
      "cmd-shift-backspace": "agent::RejectAll"
    }
  },
  {
    "context": "Editor && editor_agent_diff",
    "bindings": {
      "cmd-shift-enter": "agent::KeepAll",
      "cmd-shift-backspace": "agent::RejectAll"
    }
  },

  // =========================================================================
  // Terminal — match WezTerm muscle memory
  // =========================================================================
  {
    "context": "Terminal",
    "bindings": {
      "cmd-t": "workspace::NewTerminal",
      "cmd-w": "pane::CloseActiveItem",
      "cmd-d": "pane::SplitDown",
      "cmd-shift-d": "pane::SplitRight"
    }
  },

  // =========================================================================
  // Project panel — Zed's GUI tree (mirrors Neovim neo-tree sidebar; bulk edits via oil.nvim)
  // =========================================================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "h": "project_panel::CollapseSelectedEntry",
      "l": "project_panel::ExpandSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrev",
      "o": "project_panel::Open",
      "a": "project_panel::NewFile",
      "shift-a": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "c": "project_panel::Copy",
      "p": "project_panel::Paste",
      "?": "project_panel::ToggleFocus"
    }
  }
]
