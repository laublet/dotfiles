#
# Sets Prezto options.
#

#
# General
#

# Color output (auto set to 'no' on dumb terminals).
zstyle ':prezto:*:*' color 'yes'

#
# Modules
#
# The order matters.
# Note: 'prompt' module removed — Starship handles the prompt now.
zstyle ':prezto:load' pmodule \
  'environment' \
  'terminal' \
  'editor' \
  'history' \
  'directory' \
  'spectrum' \
  'utility' \
  'completion' \
  'autosuggestions' \
  'syntax-highlighting' \
  'history-substring-search' \
  'git' \
  'docker' \
  'node' \
  'fzf-tab'

#
# Editor
#

zstyle ':prezto:module:editor' key-bindings 'vi'
zstyle ':prezto:module:editor' dot-expansion 'yes'