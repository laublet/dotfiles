# ── Keybindings ──────────────────────────────────────────────────
# zsh-autosuggestions (prezto: vi mode)
#   Ctrl+→ / Ctrl+Shift+→ partial accept (plain → stays forward-char)
#   Ctrl+Space           accept full suggestion, do not run
#   Ctrl+Enter           accept full suggestion and run
#
# If Ctrl+→ drops you in normal mode with weird edits: the terminal sent Esc
# before the rest of the sequence — we bind \\e[1;5C as one atomic key below.

zle-autosuggest-forward() {
  if [[ -n "$POSTDISPLAY" ]] && (( CURSOR == ${#BUFFER} )); then
    if [[ $KEYMAP == vicmd ]]; then
      zle vi-forward-word
    else
      zle forward-word
    fi
  else
    if [[ $KEYMAP == vicmd ]]; then
      zle vi-forward-char
    else
      zle forward-char
    fi
  fi
}
zle -N zle-autosuggest-forward

# Override prezto vi-forward-word on Ctrl+arrows (must be whole sequences, not Esc + tail).
_autosuggest_bind_partial() {
  local keymap key
  local -a keys
  keys=(
    ${(s: :)key_info[ControlRight]}
    '\e[1;5C' '\e[5C' '\e\e[C' '\eOc'
    '\e[1;6C' '\e[6C'
  )
  for keymap in viins emacs vicmd; do
    for key in "${keys[@]}"; do
      [[ -n "$key" && "$key" != $'\ufffd' ]] || continue
      bindkey -M "$keymap" "$key" zle-autosuggest-forward
    done
  done
}
(( $+key_info )) && _autosuggest_bind_partial

bindkey -M viins '^ ' autosuggest-accept
bindkey -M emacs '^ ' autosuggest-accept

# Accept + execute (WezTerm sends Esc+Return as \\er — see wezterm.lua Ctrl+Enter)
for keymap in viins emacs; do
  bindkey -M "$keymap" '\er' autosuggest-execute
  bindkey -M "$keymap" '^[^M' autosuggest-execute
  bindkey -M "$keymap" '^[[13;5u' autosuggest-execute
done

# WezTerm Cmd+Z (macOS): agent undo is ESC[127;5u. Without a bind, vi mode treats ESC
# as vicmd then the trailing u as vi-undo-change — wipes the whole line.
wezterm-cmd-z-undo() {
  if [[ $KEYMAP == vicmd ]]; then
    zle vi-undo-change
  else
    zle undo
  fi
}
zle -N wezterm-cmd-z-undo
for keymap in viins emacs vicmd; do
  bindkey -M "$keymap" '\e[127;5u' wezterm-cmd-z-undo
  bindkey -M "$keymap" '^_' wezterm-cmd-z-undo
done

