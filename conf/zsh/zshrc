# ── WezTerm output picker — fzf widget triggered by Ctrl+Shift+O ──
# Counterpart to `pick_output_action` in .wezterm.lua. WezTerm dumps the
# pane's OSC 133 Output zones to a tmpdir, writes the path to
# /tmp/.wezterm-output-picker.<pane_id>, then sends Ctrl+X Ctrl+P to the
# tty. This widget reads the marker and runs `wezterm-output-picker` in the
# current shell, so fzf inherits FZF_DEFAULT_OPTS (--height 40% --border)
# and floats inline — identical UX to Ctrl+T / Ctrl+R, no pane split.
__wezterm_output_picker_widget() {
  local marker="/tmp/.wezterm-output-picker.${WEZTERM_PANE:-$$}"
  [[ -f "$marker" ]] || return 0
  local tmpdir
  tmpdir=$(<"$marker")
  command rm -f "$marker"
  [[ -d "$tmpdir" ]] || return 0
  command wezterm-output-picker "$tmpdir"
  zle reset-prompt
}
zle -N __wezterm_output_picker_widget
bindkey '^X^P' __wezterm_output_picker_widget

