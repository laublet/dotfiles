# Bitwarden CLI — cheat bitwarden-cli
bw-help() {
  command -v bw &>/dev/null || { echo "bw: not found — brew install bitwarden-cli" >&2; return 127; }
  local pick
  pick=$(bw --help 2>&1 \
    | awk '/^Commands:/{f=1;next} f && /^  [a-z]/ {gsub(/^  /,""); print $1}' \
    | sort -u \
    | fzf --prompt 'bw command❯ ' --height 40%)
  [[ -n "$pick" ]] && bw help "$pick" | ${PAGER:-less}
}

# Bitwarden vault status from `bw status --raw` (not unlock --check: ignores active session).
_bw_vault_status() {
  bw status --raw 2>/dev/null \
    | python3 -c "import json,sys; print(json.load(sys.stdin).get('status',''))" 2>/dev/null
}

_bw_ensure_unlocked() {
  local st
  st=$(_bw_vault_status) || {
    echo "bw status failed — run: bw login" >&2
    return 1
  }
  if [[ "$st" == "unlocked" ]]; then
    return 0
  fi
  if [[ "$st" == "locked" ]]; then
    local key
    key=$(bw unlock --raw) || return 1
    export BW_SESSION="$key"
    return 0
  fi
  echo "bw: unexpected status '$st' — run: bw login" >&2
  return 1
}

bwpick() {
  command -v bw &>/dev/null || { echo "bw: not found" >&2; return 127; }
  _bw_ensure_unlocked || return 1
  local search="${1:-}"
  local args=(list items)
  [[ -n "$search" ]] && args+=(--search "$search")

  _bwpick_copy() {
    local field="$1" name="$2"
    local val
    val=$(bw get "$field" "$name" --raw 2>/dev/null) || return 1
    if [[ "$OSTYPE" == darwin* ]]; then
      print -r -- "$val" | pbcopy
    elif command -v wl-copy &>/dev/null; then
      print -r -- "$val" | wl-copy
    elif command -v xclip &>/dev/null; then
      print -r -- "$val" | xclip -selection clipboard
    else
      print -r -- "$val"
      return 0
    fi
    echo "Copied $field for: $name"
  }

  local -a expect
  expect=("${(@f)$(bw "${args[@]}" 2>/dev/null \
    | python3 -c "
import json, sys
for it in json.load(sys.stdin):
    login = it.get('login') or {}
    print(f\"{it.get('name','')}\t{login.get('username') or ''}\t{it.get('type',0)}\")
" \
    | fzf --delimiter=$'\t' \
          --with-nth=1,2 \
          --prompt 'bw item❯ ' \
          --expect=ctrl-u,ctrl-n,ctrl-y,enter \
          --header=$'Enter=password · Ctrl-u=username · Ctrl-n=notes · Ctrl-y=print cmd' \
          --preview=$'printf "name: %s\nuser: %s\ntype: %s\n" {1} {2} {3}')}")
  [[ ${#expect[@]} -lt 2 ]] && return 0
  local key="${expect[1]}" line="${expect[2]}"
  local name="${line%%$'\t'*}"
  [[ -z "$name" ]] && return 0
  case "$key" in
    ctrl-u) _bwpick_copy username "$name" ;;
    ctrl-n) _bwpick_copy notes "$name" ;;
    ctrl-y) printf "bw get password %q\n" "$name" ;;
    *)      _bwpick_copy password "$name" ;;
  esac
}

# cheatsheets browser
cheat() {
  local dir="$HOME/dev/perso/dotfiles/cheatsheets"
  local favs="$dir/.favorites"
  local file
  file=$({
    [[ -f "$favs" ]] && while IFS= read -r f; do
      [[ -f "$dir/$f" ]] && echo "★ $f"
    done < "$favs"
    fd -e md . "$dir" -x basename {} | sort | while IFS= read -r f; do
      grep -qxF "$f" "$favs" 2>/dev/null || echo "  $f"
    done
  } | fzf --preview "bat --style=plain --color=always $dir/{2}" \
           --preview-window 'right,70%' \
           --prompt 'Cheatsheets❯ ' \
           --delimiter ' ' --nth 2 \
    | awk '{print $NF}')
  [[ -n "$file" ]] && bat --style=plain --paging=always "$dir/$file"
}

# tui — fuzzy launcher for installed TUIs / CLIs.
# Registry: cheatsheets/.tui-registry (TOOL|CATEGORY|DESCRIPTION).
# Preview: cheatsheets/<tool>.md via bat.
# nvim:<thing> entries open Neovim with a custom :command (e.g. nvim:neogit).
tui() {
  local dir="$HOME/dev/perso/dotfiles/cheatsheets"
  local registry="$dir/.tui-registry"
  if [[ ! -f "$registry" ]]; then
    echo "tui: registry not found at $registry" >&2
    return 1
  fi
  local pick tool nvim_cmd
  pick=$(awk -F'|' '!/^#/ && NF>=3 {printf "%-18s %-8s  %s\n", $1, $2, $3}' "$registry" \
    | fzf --prompt='TUI❯ ' \
          --preview-window='right,60%' \
          --preview="
            t=\$(echo {1} | sed 's/^nvim://')
            f=\"$dir/\$t.md\"
            if [[ -f \"\$f\" ]]; then
              bat --style=plain --color=always \"\$f\"
            else
              echo 'No cheatsheet for' \$t
            fi
          " \
    | awk '{print $1}')
  [[ -z "$pick" ]] && return 0
  if [[ "$pick" == nvim:* ]]; then
    nvim_cmd="${pick#nvim:}"
    case "$nvim_cmd" in
      neogit) command nvim -c "Neogit" ;;
      *)      command nvim -c "$nvim_cmd" ;;
    esac
    return
  fi
  if ! command -v "$pick" &>/dev/null; then
    echo "tui: '$pick' is not in PATH (install it via Brewfile?)" >&2
    return 1
  fi
  command "$pick"
}

# ── Ripgrep + fzf functions ──────────────────────────────────────

# Interactive ripgrep → fzf → open in editor
# Usage: rgf <pattern>
rgf() {
  [[ -z "$1" ]] && { echo "Usage: rgf <pattern>"; return 1; }
  local RG_PREFIX="rg --line-number --column --no-heading --color=always --smart-case"
  local PREVIEW_CMD
  if command -v bat &>/dev/null; then
    PREVIEW_CMD='bat --style=numbers --color=always --highlight-line {2} {1}'
  else
    PREVIEW_CMD='cat {1}'
  fi
  $RG_PREFIX "$1" | fzf --delimiter : \
    --preview "$PREVIEW_CMD" \
    --preview-window 'up,60%,border-bottom,+{2}+3/3' \
    --bind "enter:become($EDITOR {1} +{2})"
}

# Find files containing pattern → fzf → open in editor
# Usage: rgv <pattern>
rgv() {
  [[ -z "$1" ]] && { echo "Usage: rgv <pattern>"; return 1; }
  rg --files-with-matches --no-messages "$1" \
    | fzf --preview "rg --color=always --line-number '$1' {}" --preview-window="up,60%" \
    | xargs -I {} $EDITOR {} +/"$1"
}

# Search in specific file types
# Usage: rgt <file-type> <pattern>
rgt() {
  [[ -z "$1" || -z "$2" ]] && { echo "Usage: rgt <file-type> <pattern>"; return 1; }
  rg --type "$1" --color=always --line-number "$2" \
    | fzf --ansi --preview 'f=$(echo {} | awk -F: "{print \$1}"); bat --style=numbers --color=always $f 2>/dev/null || cat $f' --preview-window="up,60%"
}

# Count occurrences of a pattern
# Usage: rgc <pattern>
rgc() {
  [[ -z "$1" ]] && { echo "Usage: rgc <pattern>"; return 1; }
  rg --count-matches "$1" | sort -t: -k2 -nr
}

