# Force-open the Alpha dashboard even when persistence.nvim would otherwise
# restore a session (useful to "reset" the workspace view without typing :Alpha).
# Alpha is lazy-loaded on VimEnter; `+Alpha` and a VimEnter autocmd both run
# too early. `vim.schedule` defers the call to the next event-loop tick,
# after the whole startup chain (lazy.nvim → alpha.nvim → persistence) settles.
alias nva="nvim -c 'lua vim.schedule(function() pcall(vim.cmd, [[Alpha]]) end)'"
alias vzsh="v ~/.zshrc"
alias gu="gitui"
alias lzd="lazydocker"
# yazi: cd to last visited directory on exit
function y() {
  local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}

