# ── Obsidian (vault: ~/dev/perso/vaults/Main) ────────────────────
OBSIDIAN_VAULT="$HOME/dev/perso/vaults/Main"

# on <name> — open or create a note by name
on() { open "obsidian://open?vault=Main&file=$1"; }

# od — open today's daily note
alias od='open "obsidian://daily?vault=Main"'

# os — fuzzy search notes, open selected in Obsidian
os() {
  local note
  note=$(fd -e md . "$OBSIDIAN_VAULT" --strip-cwd-prefix -x basename {} .md \
    | fzf --preview "bat --style=plain --color=always $OBSIDIAN_VAULT/{}.md" \
           --preview-window 'right,60%' \
           --prompt 'Obsidian❯ ')
  [[ -n "$note" ]] && open "obsidian://open?vault=Main&file=$note"
}

# oq "text" — quick capture: append to today's daily note
oq() {
  local today=$(date +"%d-%m-%Y")
  local file="$OBSIDIAN_VAULT/Daily/${today}.md"
  [[ ! -f "$file" ]] && echo "# ${today}\n" > "$file"
  echo "- $(date +%H:%M) $*" >> "$file"
  echo "Captured to $today"
}

# oe — open vault in Neovim
alias oe='nvim "$OBSIDIAN_VAULT"'

# cheatsheets browser
cheat() {
  local dir="$HOME/dev/perso/dotfiles/cheatsheets"
  local favs="$dir/.favorites"
  local file
  file=$({
    [[ -f "$favs" ]] && while IFS= read -r f; do
      [[ -f "$dir/$f" ]] && echo "★ $f"
    done < "$favs"
    fd -e md . "$dir" -x basename {} | sort | while IFS= read -r f; do
      grep -qxF "$f" "$favs" 2>/dev/null || echo "  $f"
    done
  } | fzf --preview "bat --style=plain --color=always $dir/{2}" \
           --preview-window 'right,70%' \
           --prompt 'Cheatsheets❯ ' \
           --delimiter ' ' --nth 2 \
    | awk '{print $NF}')
  [[ -n "$file" ]] && bat --style=plain --paging=always "$dir/$file"
}

# tui — fuzzy launcher for installed TUIs / CLIs.
# Registry: cheatsheets/.tui-registry (TOOL|CATEGORY|DESCRIPTION).
# Preview: cheatsheets/<tool>.md via bat.
# nvim:<thing> entries open Neovim with a custom :command (e.g. nvim:neogit).
tui() {
  local dir="$HOME/dev/perso/dotfiles/cheatsheets"
  local registry="$dir/.tui-registry"
  if [[ ! -f "$registry" ]]; then
    echo "tui: registry not found at $registry" >&2
    return 1
  fi
  local pick tool nvim_cmd
  pick=$(awk -F'|' '!/^#/ && NF>=3 {printf "%-18s %-8s  %s\n", $1, $2, $3}' "$registry" \
    | fzf --prompt='TUI❯ ' \
          --preview-window='right,60%' \
          --preview="
            t=\$(echo {1} | sed 's/^nvim://')
            f=\"$dir/\$t.md\"
            if [[ -f \"\$f\" ]]; then
              bat --style=plain --color=always \"\$f\"
            else
              echo 'No cheatsheet for' \$t
            fi
          " \
    | awk '{print $1}')
  [[ -z "$pick" ]] && return 0
  if [[ "$pick" == nvim:* ]]; then
    nvim_cmd="${pick#nvim:}"
    case "$nvim_cmd" in
      neogit) command nvim -c "Neogit" ;;
      *)      command nvim -c "$nvim_cmd" ;;
    esac
    return
  fi
  if ! command -v "$pick" &>/dev/null; then
    echo "tui: '$pick' is not in PATH (install it via Brewfile?)" >&2
    return 1
  fi
  command "$pick"
}

# ── Ripgrep + fzf functions ──────────────────────────────────────

# Interactive ripgrep → fzf → open in editor
# Usage: rgf <pattern>
rgf() {
  [[ -z "$1" ]] && { echo "Usage: rgf <pattern>"; return 1; }
  local RG_PREFIX="rg --line-number --column --no-heading --color=always --smart-case"
  local PREVIEW_CMD
  if command -v bat &>/dev/null; then
    PREVIEW_CMD='bat --style=numbers --color=always --highlight-line {2} {1}'
  else
    PREVIEW_CMD='cat {1}'
  fi
  $RG_PREFIX "$1" | fzf --delimiter : \
    --preview "$PREVIEW_CMD" \
    --preview-window 'up,60%,border-bottom,+{2}+3/3' \
    --bind "enter:become($EDITOR {1} +{2})"
}

# Find files containing pattern → fzf → open in editor
# Usage: rgv <pattern>
rgv() {
  [[ -z "$1" ]] && { echo "Usage: rgv <pattern>"; return 1; }
  rg --files-with-matches --no-messages "$1" \
    | fzf --preview "rg --color=always --line-number '$1' {}" --preview-window="up,60%" \
    | xargs -I {} $EDITOR {} +/"$1"
}

# Search in specific file types
# Usage: rgt <file-type> <pattern>
rgt() {
  [[ -z "$1" || -z "$2" ]] && { echo "Usage: rgt <file-type> <pattern>"; return 1; }
  rg --type "$1" --color=always --line-number "$2" \
    | fzf --ansi --preview 'f=$(echo {} | awk -F: "{print \$1}"); bat --style=numbers --color=always $f 2>/dev/null || cat $f' --preview-window="up,60%"
}

# Count occurrences of a pattern
# Usage: rgc <pattern>
rgc() {
  [[ -z "$1" ]] && { echo "Usage: rgc <pattern>"; return 1; }
  rg --count-matches "$1" | sort -t: -k2 -nr
}

