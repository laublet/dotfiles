export FZF_ALT_C_OPTS="--preview 'tree -C {} | head -200'"

# Interactive ripgrep with fzf
# Usage: rgf <search-term>
rgf() {
  [[ -z "$1" ]] && { echo "Usage: rgf <pattern>"; return 1; }
  
  local RG_PREFIX="rg --line-number --column --no-heading --color=always --smart-case"
  local PREVIEW_CMD
  
  if command -v bat &>/dev/null; then
    PREVIEW_CMD='bat --style=numbers --color=always --highlight-line {2} {1}'
  else
    PREVIEW_CMD='cat {1}'
  fi
  
  $RG_PREFIX "$1" | fzf --delimiter : \
    --preview "$PREVIEW_CMD" \
    --preview-window 'up,60%,border-bottom,+{2}+3/3' \
    --bind 'enter:become(vim {1} +{2})'
}

# Lazy-load ripgrep functions by creating stubs that load the real functions when called
# Find files containing pattern and open in editor
# Usage: rgv <pattern>
rgv() {
  # Define the actual function
  _rgv() {
    local pattern="${1:-}"
    [[ -z "$pattern" ]] && { echo "Usage: rgv <pattern>"; return 1; }
    
    rg --files-with-matches --no-messages "$pattern" | fzf --preview "rg --color=always --line-number '$pattern' {}" --preview-window="up,60%" | xargs -I {} $EDITOR {} +/"$pattern"
  }
  
  # Replace the stub with the real function and run it
  unfunction rgv
  function rgv() { _rgv "$@"; }
  rgv "$@"
}

# Search for pattern in specified file types
# Usage: rgt <file-type> <pattern>
rgt() {
  # Define the actual function
  _rgt() {
    local type="$1"
    local pattern="$2"
    [[ -z "$type" || -z "$pattern" ]] && { echo "Usage: rgt <file-type> <pattern>"; return 1; }
    
    rg --type "$type" --color=always --line-number "$pattern" | fzf --ansi --preview 'f=$(echo {} | awk -F: "{print \$1}"); cat $f' --preview-window="up,60%"
  }
  
  # Replace the stub with the real function and run it
  unfunction rgt
  function rgt() { _rgt "$@"; }
  rgt "$@"
}

# Count occurrences of a pattern
# Usage: rgc <pattern>
rgc() {
  # Define the actual function
  _rgc() {
    local pattern="${1:-}"
    [[ -z "$pattern" ]] && { echo "Usage: rgc <pattern>"; return 1; }
    
    rg --count-matches "$pattern" | sort -t: -k2 -nr
  }
  
  # Replace the stub with the real function and run it
  unfunction rgc
  function rgc() { _rgc "$@"; }
  rgc "$@"
}

