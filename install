#!/usr/bin/env bash

DOTBOT_DIR="dotbot"
DOTBOT_BIN="bin/dotbot"
BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

cd "${BASEDIR}"
git -C "${DOTBOT_DIR}" submodule sync --quiet --recursive
git submodule update --init --recursive "${DOTBOT_DIR}"

status=0

# Shared dotfiles
"${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "install.conf.yaml" "${@}" || status=1

# OS-specific dotfiles — always run even if shared link step reported errors
OS="$(uname -s)"
if [[ "$OS" == "Darwin" && -f "install-mac.conf.yaml" ]]; then
  "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "install-mac.conf.yaml" "${@}" || status=1
elif [[ "$OS" == "Linux" && -f "install-linux.conf.yaml" ]]; then
  "${BASEDIR}/${DOTBOT_DIR}/${DOTBOT_BIN}" -d "${BASEDIR}" -c "install-linux.conf.yaml" "${@}" || status=1
fi

exit "$status"
