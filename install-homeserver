#!/usr/bin/env bash
# Home server — same dotfiles as install-server (shell, vim, git, zellij, starship).
# Extra dev/editor configs (neovim, yazi, …) live in server/install-full.conf.yaml;
# run Dotbot on that file manually if you need them on a machine.

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "${BASEDIR}/install-server" "${@}"
