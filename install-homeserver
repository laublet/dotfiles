#!/usr/bin/env bash
# Home server — same dotfiles as install-server (shell, nvim+vim, git, zellij,
# starship, atuin, mise, lazygit). Heavier extras (yazi, lazydocker, btop,
# bottom) live in server/install-full.conf.yaml; run dotbot on that file
# manually if you need them on a machine.

set -e

BASEDIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec "${BASEDIR}/install-server" "${@}"
